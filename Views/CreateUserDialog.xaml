<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="PartTracker.Views.CreateUserDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Vytvořit nového mechanika"
    PrimaryButtonText="Vytvořit"
    SecondaryButtonText="Zrušit"
    Background="#1E1E1E"
    Foreground="#FFFFFF">
    <StackPanel Spacing="15" Width="350">
        <TextBlock Text="ID mechanika" FontSize="14" />
        <TextBox
            x:Name="UserIdInput"
            PlaceholderText="Zadejte jedinečné ID"
            Height="40"
            Padding="10"
            Background="#2E2E2E"
            Foreground="#FFFFFF" />
        
        <TextBlock Text="Heslo" FontSize="14" />
        <PasswordBox
            x:Name="PasswordInput"
            Height="40"
            Padding="10"
            Background="#2E2E2E"
            Foreground="#FFFFFF" />
        
        <TextBlock
            x:Name="ErrorMessage"
            Foreground="#FF6B6B"
            FontSize="12"
            TextWrapping="Wrap" />
    </StackPanel>
</ContentDialog>