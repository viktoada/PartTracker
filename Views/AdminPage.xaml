<?xml version="1.0" encoding="utf-8"?>\n<Window\n    x:Class="PartTracker.Views.AdminPage"\n    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"\n    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"\n    Title="PartTracker - Správce"\n    Width="800"\n    Height="600"\n    Background="#1E1E1E"\n    Foreground="#FFFFFF">\n    <Grid Padding="20">\n        <Grid.RowDefinitions>\n            <RowDefinition Height="Auto" />\n            <RowDefinition Height="Auto" />\n            <RowDefinition Height="*" />\n            <RowDefinition Height="Auto" />\n        </Grid.RowDefinitions>\n        \n        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" HorizontalAlignment="SpaceBetween">\n            <TextBlock Text="Správa PartTracker" FontSize="20" FontWeight="Bold" />\n            <Button\n                Content="Odhlásit se"\n                Click="OnLogoutClick"\n                Background="#FF6B6B"\n                Foreground="#FFFFFF" />\n        </StackPanel>\n        \n        <TabView Grid.Row="1" Grid.RowSpan="2">\n            <TabViewItem Header="Importovat díly" IconSource="Download">\n                <StackPanel Padding="20" Spacing="15">\n                    <TextBlock Text="Importovat díly z Excel souboru" FontSize="16" FontWeight="Bold" />\n                    <TextBlock\n                        Text="Vyberte Excel soubor s díly (sloupce: Code, Name, Description)\"\n                        TextWrapping=\"Wrap\"\n                        Foreground=\"#AAAAAA\" />\n                    <Button\n                        Content=\"📁 Vybrat soubor\"\n                        Height=\"40\"\n                        Background=\"#2196F3\"\n                        Foreground=\"#FFFFFF\"\n                        Click=\"OnSelectExcelClick\" />\n                    <TextBlock\n                        x:Name=\"ImportStatus\"\n                        Foreground=\"#AAAAAA\"\n                        TextWrapping=\"Wrap\" />\n                    <ProgressRing\n                        x:Name=\"ImportProgress\"\n                        IsActive=\"False\"\n                        Width=\"30\"\n                        Height=\"30\" />\n                </StackPanel>\n            </TabViewItem>\n            \n            <TabViewItem Header=\"Exportovat demontáž\" IconSource=\"Upload\">\n                <StackPanel Padding=\"20\" Spacing=\"15\">\n                    <TextBlock Text=\"Exportovat demontované díly\" FontSize=\"16\" FontWeight=\"Bold\" />\n                    <TextBlock\n                        Text=\"Vygeneruje seznam všech demontovaných dílů pro reportování\"\n                        TextWrapping=\"Wrap\"\n                        Foreground=\"#AAAAAA\" />\n                    <Button\n                        Content=\"💾 Exportovat do Excel\"\n                        Height=\"40\"\n                        Background=\"#4CAF50\"\n                        Foreground=\"#FFFFFF\"\n                        Click=\"OnExportClick\" />\n                    <TextBlock\n                        x:Name=\"ExportStatus\"\n                        Foreground=\"#AAAAAA\"\n                        TextWrapping=\"Wrap\" />\n                </StackPanel>\n            </TabViewItem>\n            \n            <TabViewItem Header=\"Logy tisku\" IconSource=\"Mail\">\n                <StackPanel Padding=\"20\" Spacing=\"15\">\n                    <StackPanel Orientation=\"Horizontal\" Spacing=\"10\">\n                        <TextBlock Text=\"Historie tisknutí štítků\" FontSize=\"16\" FontWeight=\"Bold\" />\n                        <Button\n                            Content=\"🔄 Obnovit\"\n                            Height=\"35\"\n                            Background=\"#2196F3\"\n                            Foreground=\"#FFFFFF\"\n                            Click=\"OnRefreshLogsClick\" />\n                    </StackPanel>\n                    <ListView x:Name=\"PrintLogsList\" Height=\"300\">\n                        <ListView.ItemContainerStyle>\n                            <Style TargetType=\"ListViewItem\">\n                                <Setter Property=\"Height\" Value=\"30\" />\n                            </Style>\n                        </ListView.ItemContainerStyle>\n                    </ListView>\n                </StackPanel>\n            </TabViewItem>\n            \n            <TabViewItem Header=\"Uživatelé\" IconSource=\"People\">\n                <StackPanel Padding=\"20\" Spacing=\"15\">\n                    <TextBlock Text=\"Správa uživatelů\" FontSize=\"16\" FontWeight=\"Bold\" />\n                    <Button\n                        Content=\"➕ Vytvořit nového mechanika\"\n                        Height=\"40\"\n                        Background=\"#4CAF50\"\n                        Foreground=\"#FFFFFF\"\n                        Click=\"OnCreateUserClick\" />\n                    <TextBlock\n                        Text=\"Zadejte ID a heslo pro nového mechanika\"\n                        TextWrapping=\"Wrap\"\n                        Foreground=\"#AAAAAA\" />\n                </StackPanel>\n            </TabViewItem>\n        </TabView>\n        \n        <TextBlock\n            Grid.Row="3"\n            Text=\"© 2026 PartTracker. Všechna práva vyhrazena.\"\n            FontSize=\"10\"\n            Foreground=\"#666666\"\n            HorizontalAlignment=\"Center\" />\n    </Grid>\n</Window>