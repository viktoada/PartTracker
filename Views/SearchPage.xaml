<?xml version="1.0" encoding="utf-8"?>\n<Window\n    x:Class="PartTracker.Views.SearchPage"\n    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"\n    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"\n    Title="PartTracker - Vyhledávání"\n    Width="600"\n    Height="500"\n    Background="#1E1E1E"\n    Foreground="#FFFFFF">\n    <Grid Padding="20" RowSpacing="15">\n        <Grid.RowDefinitions>\n            <RowDefinition Height="Auto\" />\n            <RowDefinition Height=\"Auto\" />\n            <RowDefinition Height=\"Auto\" />\n            <RowDefinition Height=\"*\" />\n            <RowDefinition Height=\"Auto\" />\n        </Grid.RowDefinitions>\n        \n        <StackPanel Grid.Row=\"0\" Orientation=\"Horizontal\" Spacing=\"10\" HorizontalAlignment=\"SpaceBetween\">\n            <TextBlock\n                x:Name=\"UserInfo\"\n                FontSize=\"14\"\n                Foreground=\"#4CAF50\" />\n            <Button\n                Content=\"Odhlásit se\"\n                Click=\"OnLogoutClick\"\n                Background=\"#FF6B6B\"\n                Foreground=\"#FFFFFF\" />\n        </StackPanel>\n        \n        <StackPanel Grid.Row=\"1\" Spacing=\"10\">\n            <TextBlock Text=\"Zadejte kód dílu (5 číslic)\" FontSize=\"16\" FontWeight=\"Bold\" />\n            <Grid ColumnSpacing=\"10\" Columns=\"*,Auto\">\n                <TextBox\n                    x:Name=\"CodeInput\"\n                    Grid.Column=\"0\"\n                    PlaceholderText=\"Např. 12345\"\n                    Height=\"40\"\n                    Padding=\"10\"\n                    Background=\"#2E2E2E\"\n                    Foreground=\"#FFFFFF\"\n                    KeyDown=\"OnCodeInputKeyDown\" />\n                <Button\n                    Grid.Column=\"1\"\n                    Content=\"Vyhledat\"\n                    Width=\"100\"\n                    Height=\"40\"\n                    Background=\"#4CAF50\"\n                    Foreground=\"#FFFFFF\"\n                    Click=\"OnSearchClick\" />\n            </Grid>\n        </StackPanel>\n        \n        <ScrollViewer Grid.Row=\"3\" VerticalScrollMode=\"Auto\">\n            <StackPanel\n                x:Name=\"ResultPanel\"\n                Spacing=\"10\" />\n        </ScrollViewer>\n        \n        <StackPanel Grid.Row=\"4\" Orientation=\"Horizontal\" Spacing=\"10\" HorizontalAlignment=\"Center\">\n            <Button\n                x:Name=\"PrintButton\"\n                Content=\"🖨️ Vytisknout štítek\"\n                Height=\"40\"\n                Padding=\"15,0\"\n                Background=\"#2196F3\"\n                Foreground=\"#FFFFFF\"\n                IsEnabled=\"False\"\n                Click=\"OnPrintClick\" />\n        </StackPanel>\n    </Grid>\n</Window>