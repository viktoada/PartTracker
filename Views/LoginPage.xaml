<?xml version="1.0" encoding="utf-8"?>\n<Window\n    x:Class="PartTracker.Views.LoginPage"\n    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"\n    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"\n    Title="PartTracker - Přihlášení"\n    Width="400"\n    Height="300"\n    Background="#1E1E1E"\n    Foreground="#FFFFFF">\n    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">\n        <StackPanel Spacing="15">\n            <TextBlock\n                Text="PartTracker"\n                FontSize="32"\n                FontWeight="Bold"\n                Foreground="#4CAF50\"\n                HorizontalAlignment="Center\" />\n            <TextBlock\n                Text=\"Přihlášení\"\n                FontSize=\"18\"\n                HorizontalAlignment=\"Center\" />\n            \n            <TextBlock Text=\"ID mechanika\" FontSize=\"14\" />\n            <TextBox\n                x:Name=\"UsernameInput\"\n                PlaceholderText=\"Zadejte vaše ID\"\n                Height=\"40\"\n                Padding=\"10\"\n                Background=\"#2E2E2E\"\n                Foreground=\"#FFFFFF\" />\n            \n            <TextBlock Text=\"Heslo\" FontSize=\"14\" />\n            <PasswordBox\n                x:Name=\"PasswordInput\"\n                Height=\"40\"\n                Padding=\"10\"\n                Background=\"#2E2E2E\"\n                Foreground=\"#FFFFFF\" />\n            \n            <TextBlock\n                x:Name=\"ErrorMessage\"\n                Foreground=\"#FF6B6B\"\n                FontSize=\"12\"\n                TextWrapping=\"Wrap\" />\n            \n            <Button\n                x:Name=\"LoginButton\"\n                Content=\"Přihlásit se\"\n                Height=\"40\"\n                Background=\"#4CAF50\"\n                Foreground=\"#FFFFFF\"\n                FontSize=\"14\"\n                Click=\"OnLoginClick\" />\n            \n            <ProgressRing\n                x:Name=\"LoadingRing\"\n                IsActive=\"False\"\n                Width=\"30\"\n                Height=\"30\"\n                HorizontalAlignment=\"Center\" />\n        </StackPanel>\n    </Grid>\n</Window>